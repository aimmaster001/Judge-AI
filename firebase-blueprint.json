{
  "entities": {
    "IdeaRoom": {
      "title": "Idea Room",
      "description": "Represents a startup idea validation space.",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "userId": { "type": "string" },
        "ideaName": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["roomId", "userId", "ideaName", "description", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within an idea room conversation.",
      "type": "object",
      "properties": {
        "messageId": { "type": "string" },
        "roomId": { "type": "string" },
        "userId": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "ai"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["messageId", "roomId", "userId", "sender", "content", "timestamp"]
    },
    "Report": {
      "title": "Report",
      "description": "A startup evaluation report generated by AI.",
      "type": "object",
      "properties": {
        "reportId": { "type": "string" },
        "roomId": { "type": "string" },
        "userId": { "type": "string" },
        "score": { "type": "integer" },
        "summary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reportId", "roomId", "userId", "score", "summary", "createdAt"]
    }
  },
  "firestore": {
    "/ideaRooms/{roomId}": {
      "schema": { "$ref": "#/entities/IdeaRoom" },
      "description": "Collection of startup idea rooms."
    },
    "/ideaRooms/{roomId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Subcollection of messages within a room."
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Collection of generated evaluation reports."
    }
  }
}
